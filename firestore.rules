rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    // Helper function to check if user owns the church profile
    function isChurchOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function to get the authenticated user's churchId safely
    function getUserChurchId() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.churchId
        : null;
    }
    
    // Helper function to check if the authenticated user is an admin or owns the target churchId
    function isChurchAdminOwner(targetChurchId) {
      return isAdmin() || (request.auth != null && getUserChurchId() == targetChurchId);
    }

    // Applications collection rules
    match /applications/{applicationId} {
      allow read: if resource.data.status == 'APPROVED'; // Publicly readable if approved
      allow read: if request.auth != null; // Authenticated users can read
      
      // Allow unauthenticated users to CREATE applications (new workflow)
      // Debug: Nuclear option to verify deployment to named database
      allow create: if true;
      
      // Allow authenticated users to create applications with their userId (legacy/admin)
      allow create: if request.auth != null 
                    && request.resource.data.status == 'PENDING'
                    && request.resource.data.userId == request.auth.uid;
      
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin();
      
      allow update: if isChurchOwner(resource.data.userId)
                    && resource.data.status == 'APPROVED'
                    && request.resource.data.status == 'APPROVED';
    }

    // Settings collection rules
    match /settings/{documentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // User Profiles collection rules
    match /userProfiles/{userId} {
      allow read, write: if isAdmin();
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Church Statistics collection rules
    match /churchStats/{churchId} {
      allow read: if isAdmin();
      allow read: if isChurchAdminOwner(churchId);
      
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visits', 'contacts', 'views', 'socialClicks', 'lastUpdated'])
                    && request.resource.data.visits >= resource.data.visits
                    && request.resource.data.contacts >= resource.data.contacts
                    && request.resource.data.views >= resource.data.views;
      
      allow create, update, delete: if isAdmin();
    }

    // Church Events collection rules
    match /churchEvents/{eventId} {
      // Admins can do everything (including queries with where clauses)
      allow read, write: if isAdmin();
      
      // Any authenticated user can create events (tracking)
      allow create: if request.auth != null;
      
      // Church owners can read their own events (document-level only)
      allow get: if request.auth != null 
                 && resource.data.churchId != null
                 && isChurchAdminOwner(resource.data.churchId);
    }

    // Job Listings collection rules
    match /jobListings/{jobId} {
      // Simplified read rule to prevent crashes: Authenticated users can read all jobs
      // Active jobs are readable by everyone
      allow read: if resource.data.status == 'active' || request.auth != null;

      // Strict write rules maintained
      allow create: if isChurchAdminOwner(request.resource.data.churchId);
      allow update: if isChurchAdminOwner(resource.data.churchId);
      allow delete: if isChurchAdminOwner(resource.data.churchId);

      // Admins
      allow read, create, update, delete: if isAdmin();
    }

    // Job Applications collection rules
    match /jobApplications/{applicationId} {
      allow create: if true;

      allow read, update, delete: if request.auth != null && isChurchAdminOwner(resource.data.churchId);
      
      allow read, update, delete: if isAdmin();
    }

    // Promo Codes collection rules
    match /promoCodes/{promoCode} {
      allow get: if true; // Allow public verification of individual codes
      allow list: if isAdmin(); // Only admins can list all codes
      allow write: if isAdmin();
    }
  }
}
