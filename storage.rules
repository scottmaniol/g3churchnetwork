rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /logos/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
    match /resumes/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
    match /images/{allPaths=**} {
      allow read;
    }
  }
}
